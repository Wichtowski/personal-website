{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personal-website",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.ts",
  "routes": [
    {
      "pattern": "oskarwichtowski.com",
      "custom_domain": true
    },
    {
      "pattern": "www.oskarwichtowski.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  },
  "vars": {
    "LASTFM_API_KEY": "50004b4cea67510ae9d95ea846887175",
    "LASTFM_USERNAME": "oshkyy",
    "LASTFM_SHARED_SECRET": "058dc0e82d2ade2d51bb5d162762f12d"
  }
}
